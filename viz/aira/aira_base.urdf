       frame di rotazione senza geometria. Camera montata sulla testa (livellabile via busto/testa). --><material name="torso_mat"><color rgba="0.30 0.34 0.40 1.0"/></material><material name="head_mat"><color rgba="0.85 0.85 0.88 1.0"/></material><material name="cam_mat"><color rgba="0.10 0.10 0.12 1.0"/></material><!-- montante fisso: dalla base al perno del busto --><link name="mast_link"><visual><origin rpy="0 0 0" xyz="0 0 0.25"/><geometry><box size="0.04 0.04 0.5"/></geometry><material name="alu"/></visual><collision><origin rpy="0 0 0" xyz="0 0 0.25"/><geometry><box size="0.04 0.04 0.5"/></geometry></collision><inertial><mass value="1.0"/><inertia ixx="0.020966666666666665" ixy="0" ixz="0" iyy="0.020966666666666665" iyz="0" izz="0.0002666666666666667"/></inertial></link><joint name="mast_joint" type="fixed"><parent link="base_link"/><child link="mast_link"/><origin rpy="0 0 0" xyz="0 0 0"/></joint><link name="torso_pitch_link"><inertial><mass value="0.05"/><inertia ixx="1e-4" ixy="0" ixz="0" iyy="1e-4" iyz="0" izz="1e-4"/></inertial></link><joint name="torso_pitch" type="revolute"><parent link="mast_link"/><child link="torso_pitch_link"/><origin rpy="0 0 0" xyz="0 0 0.5"/><axis xyz="0 1 0"/><limit effort="80" lower="-0.5235987755982988" upper="0.7853981633974483" velocity="2.0"/></joint><link name="torso_link"><visual><origin rpy="0 0 0" xyz="0 0 0.15"/><geometry><box size="0.14 0.18 0.3"/></geometry><material name="torso_mat"/></visual><collision><origin rpy="0 0 0" xyz="0 0 0.15"/><geometry><box size="0.14 0.18 0.3"/></geometry></collision><inertial><mass value="2.0"/><inertia ixx="0.020399999999999998" ixy="0" ixz="0" iyy="0.018266666666666667" iyz="0" izz="0.008666666666666668"/></inertial></link><joint name="torso_tilt" type="revolute"><parent link="torso_pitch_link"/><child link="torso_link"/><origin rpy="0 0 0" xyz="0 0 0"/><axis xyz="1 0 0"/><limit effort="80" lower="-0.4363323129985824" upper="0.4363323129985824" velocity="2.0"/></joint><!-- collo fisso in cima al busto --><link name="neck_link"><visual><origin rpy="0 0 0" xyz="0 0 0.03"/><geometry><cylinder length="0.06" radius="0.02"/></geometry><material name="alu"/></visual><inertial><mass value="0.1"/><inertia ixx="3.9999999999999996e-05" ixy="0" ixz="0" iyy="3.9999999999999996e-05" iyz="0" izz="2e-05"/></inertial></link><joint name="neck_joint" type="fixed"><parent link="torso_link"/><child link="neck_link"/><origin rpy="0 0 0" xyz="0 0 0.3"/></joint><link name="head_pan_link"><inertial><mass value="0.05"/><inertia ixx="1e-4" ixy="0" ixz="0" iyy="1e-4" iyz="0" izz="1e-4"/></inertial></link><joint name="head_pan" type="revolute"><parent link="neck_link"/><child link="head_pan_link"/><origin rpy="0 0 0" xyz="0 0 0.06"/><axis xyz="0 0 1"/><limit effort="10" lower="-1.5707963267948966" upper="1.5707963267948966" velocity="3.0"/></joint><link name="head_tilt_link"><inertial><mass value="0.05"/><inertia ixx="1e-4" ixy="0" ixz="0" iyy="1e-4" iyz="0" izz="1e-4"/></inertial></link><joint name="head_tilt" type="revolute"><parent link="head_pan_link"/><child link="head_tilt_link"/><origin rpy="0 0 0" xyz="0 0 0"/><axis xyz="1 0 0"/><limit effort="10" lower="-0.7853981633974483" upper="0.7853981633974483" velocity="3.0"/></joint><link name="head_link"><visual><origin rpy="0 0 0" xyz="0 0 0.07"/><geometry><box size="0.12 0.12 0.14"/></geometry><material name="head_mat"/></visual><collision><origin rpy="0 0 0" xyz="0 0 0.07"/><geometry><box size="0.12 0.12 0.14"/></geometry></collision><inertial><mass value="0.6"/><inertia ixx="0.0017000000000000001" ixy="0" ixz="0" iyy="0.0017000000000000001" iyz="0" izz="0.00144"/></inertial></link><joint name="head_pitch" type="revolute"><parent link="head_tilt_link"/><child link="head_link"/><origin rpy="0 0 0" xyz="0 0 0"/><axis xyz="0 1 0"/><limit effort="10" lower="-0.7853981633974483" upper="0.7853981633974483" velocity="3.0"/></joint><!-- depth camera sulla testa (placeholder): frame 'camera_link' = frame del driver realsense.
